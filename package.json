{
  "name": "kylieis-online",
  "private": true,
  "description": "Kylie Czajkowski's personal website, rebuilt on Cloudflare Workers",
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsx scripts/build-static.mjs",
    "deploy": "npm run build && wrangler deploy",
    "deploy:preview": "npm run build && wrangler deploy --env preview",
    "deploy:draft": "tsx scripts/deploy-draft.mjs",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test tests/e2e"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.0",
    "hono": "^4.7.5",
    "hono-og": "^0.0.29",
    "marked": "^15.0.7",
    "marked-highlight": "^2.2.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  }
}
